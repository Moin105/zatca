# Local Postgres (default if DATABASE_URL is not set)
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=zatca_einvoicing

# Neon (recommended): set DATABASE_URL and enable SSL
# Example format:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxx-xxxxxx.us-east-2.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL=

# SSL flags (used automatically when DATABASE_URL is present)
DB_SSL=true
# Neon typically works with rejectUnauthorized=false
DB_SSL_REJECT_UNAUTHORIZED=false

